---
import AppLayout from '../layouts/AppLayout.astro';
import Hero from '../components/Hero';
import Calculator from '../components/Calculator';
import BeyondTrumpAccounts from '../components/BeyondTrumpAccounts';
import { simulateCollegeSavings } from '../lib/calculator';

import YahooFinance from 'yahoo-finance2';
const yahooFinance = new YahooFinance();

// Fallbacks matching historical S&P 500 behavior, expressed at the monthly horizon
// because the simulator now compounds 12 monthly draws per year (not one annual draw).
// Defaults are derived so the implied annual values match prior behavior:
//   (1 + 0.0099)^12 - 1 ≈ 12.5%   monthly std × √12 ≈ 16.9%
let monthlyMean = 0.0099;
let monthlyVol  = 0.0488;
let dataRangeConfig = "1950-2024 (Fallback)";

try {
  // Use yahoo-finance2 to fetch REAL historical data for ^GSPC at build time!
  // Note: historical() is deprecated, so we use chart() and extract quotes.
  const query = '^GSPC';
  const queryOptions = { period1: new Date('1950-01-01'), period2: new Date(), interval: '1mo' as const };
  const chartResult = await yahooFinance.chart(query, queryOptions);
  const result = chartResult.quotes;

  if (result && result.length > 24) {
    const firstYear = new Date(result[0].date).getFullYear();
    const lastYear = new Date(result[result.length - 1].date).getFullYear();

    const monthlyReturns = [];
    for(let i = 1; i < result.length; i++) {
        monthlyReturns.push( (result[i].close - result[i-1].close) / result[i-1].close );
    }

    const meanMonthly = monthlyReturns.reduce((a,b)=>a+b, 0) / monthlyReturns.length;
    let varSum = 0;
    for(const r of monthlyReturns) varSum += Math.pow(r - meanMonthly, 2);
    const varMonthly = varSum / monthlyReturns.length;

    monthlyMean = meanMonthly;
    monthlyVol  = Math.sqrt(varMonthly);
    dataRangeConfig = `${firstYear}—${lastYear}`;

    const annualizedDisplay = Math.pow(1 + monthlyMean, 12) - 1;
    const annualizedVolDisplay = monthlyVol * Math.sqrt(12);
    console.log(`[Astro Build] Fetched real market data: Annualized Mean = ${(annualizedDisplay*100).toFixed(2)}%, Annualized Vol = ${(annualizedVolDisplay*100).toFixed(2)}%`);
  }
} catch (e) {
   console.error("[Astro Build] Using fallback parameters for SP500 due to Yahoo Finance error", e);
}

const previewSim = simulateCollegeSavings({
  annualContribution: 5000,
  employerMatchAnnual: 0,
  universityType: 'public',
  yearsToMatriculation: 18,
  monthlyMean,
  monthlyVol
});
const previewMedianBalance = previewSim.medianSavings;

const title = "College Savings Planner | Build Wealth Through Stable Investing";
const description = "Model Trump Account projections, then discover why low-cost index funds and treasury bonds are the evidence-backed foundation for any education savings strategy.";
---

<AppLayout activeTab="calculator" title={title} description={description}>
  <section class="route-page route-page--calculator">
    <Hero client:load dataRangeConfig={dataRangeConfig} previewMedianBalance={previewMedianBalance} />

    <section class="container section-spacing" style="padding-top: 0;">
      <div class="section-frame section-frame--calculator">
        <div class="section-intro">
          <span class="section-kicker">Trump Account Calculator</span>
          <h2 class="section-title">Run the numbers on the proposed Section 530A account.</h2>
          <p class="section-copy">
            Adjust savings, employer match, and college target to see 1,000 simulated market-driven outcomes.
            Then scroll past the calculator to explore why stable, low-cost investing is the real engine
            behind any education savings strategy.
          </p>
        </div>

        <Calculator
          client:only="react"
          monthlyMean={monthlyMean}
          monthlyVol={monthlyVol}
          dataRangeConfig={dataRangeConfig}
        />
      </div>
    </section>

    <BeyondTrumpAccounts client:visible />
  </section>
</AppLayout>
