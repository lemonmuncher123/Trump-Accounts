---
import AppLayout from '../layouts/AppLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const milestones = [
  {
    age: 'Birth',
    title: 'Modeled starter deposit',
    copy: 'Eligible 2025–2028 birth-year scenarios model the $1,000 pilot deposit at year zero; other birth years start with no federal seed.',
    tone: 'seed'
  },
  {
    age: 'Setup',
    title: 'Account activation',
    copy: 'In real life this still requires SSN, custodian onboarding, and — under proposed regulations — an explicit federal election to receive the pilot deposit.',
    tone: 'watch'
  },
  {
    age: 'Up to 18 growth years',
    title: 'Compounding window',
    copy: 'Family savings (capped at $5,000/yr) and optional employer contributions (up to $2,500/yr) compound across up to 18 years, depending on the child\'s birth year.',
    tone: 'growth'
  },
  {
    age: 'Age 18',
    title: 'IRA-style handoff',
    copy: 'Proposed regulations describe an IRA-like structure at adulthood: contributions are basis, earnings are tax-deferred, not tax-free.',
    tone: 'transition'
  }
];

const lifecycle = [
  {
    step: '01',
    eyebrow: 'Setup',
    title: 'Establish the account and claim the modeled starting deposit.',
    copy: 'Under current federal guidance the account is open to an eligible minor with a valid SSN, subject to the federal election and account setup rules; the $1,000 pilot deposit is a separate, narrower entitlement.',
    tag: 'Eligibility first',
    tone: 'seed',
    points: [
      'Account eligibility: any U.S. child under 18 with a Social Security Number, once an approved custodian offers the product.',
      'Pilot $1,000 deposit: limited to U.S.-citizen children born between 2025 and 2028.',
      'Election and custodian onboarding details remain governed by proposed federal regulations issued in 2025.'
    ]
  },
  {
    step: '02',
    eyebrow: 'Growth',
    title: 'Add family savings and let up to 18 years of compounding do the heavy lifting.',
    copy: 'The simulator treats the account as a long-duration savings runway: capped annual contributions, optional employer support, and market-style return paths.',
    tag: 'Up to 18 years',
    tone: 'growth',
    points: [
      'Total annual contributions are capped at $5,000 per year (current statutory limit), including both family and employer dollars.',
      'Employer contributions are federally tax-free up to $2,500 per year (§128 exclusion) but count toward the $5,000 aggregate cap.',
      'Returns are sampled monthly (12 compounds per year) and replayed across 1,000 market-style paths.'
    ]
  },
  {
    step: '03',
    eyebrow: 'Transition',
    title: 'Read the at-18 balance, then layer the tax rules separately.',
    copy: 'The Simulation tab shows the account balance at age 18. Federal and California tax treatment is layered on the Tax Analysis tab, not baked into the headline number.',
    tag: 'Age-18 handoff',
    tone: 'transition',
    points: [
      'Proposed regulations describe an IRA-like structure: contributions are basis, earnings are tax-deferred.',
      'Education, first-home, and medical uses qualify for an exception to the 10% early-withdrawal penalty.',
      'Rollover, financial-aid (now SAI, not EFC), and final state tax handling still require close attention.'
    ]
  }
];

const drivers = [
  {
    value: '2009–2028',
    title: 'Child birth year',
    copy: 'Determines whether the $1,000 pilot seed is included (2025–2028 only), when contributions begin (no earlier than 2026), and the transition year when the child turns 18.'
  },
  {
    value: '$1,000',
    title: 'Pilot federal seed',
    copy: 'The $1,000 pilot deposit is credited at year zero only for birth years 2025–2028. Other birth years start with no seed.'
  },
  {
    value: 'Up to $5,000/yr',
    title: 'Family savings',
    copy: 'The annual contribution slider is capped at the current federal family limit of $5,000 per year.'
  },
  {
    value: 'Up to $2,500/yr',
    title: 'Employer contribution',
    copy: 'Employers may contribute up to $2,500 per year (§128 exclusion), counted within the $5,000 aggregate annual cap. The slider models that statutory ceiling.'
  },
  {
    value: 'Public / Private',
    title: 'Tuition target',
    copy: 'A stochastic tuition path is grown from a 4-year base cost, so each simulated future faces its own inflation-adjusted bill.'
  },
  {
    value: '1,000 paths × 12/yr',
    title: 'Return engine',
    copy: 'Returns are drawn monthly from S&P 500 statistics and compounded 12 times per simulated year, replayed across 1,000 independent paths.'
  }
];

const outputs = [
  {
    title: 'Median End Balance',
    copy: 'The midpoint savings result across all simulated paths.'
  },
  {
    title: 'Est. 4-Year Tuition',
    copy: 'The midpoint projected cost of the selected college target after inflation.'
  },
  {
    title: 'Success Rate',
    copy: 'The share of simulations where projected savings fully cover projected tuition.'
  },
  {
    title: 'Scenario field',
    copy: 'Each dot is one possible future, so you can see whether the cloud clears the tuition line or clusters below it.'
  }
];

const watchpoints = [
  {
    pill: 'Proposed regulations',
    title: 'Claiming workflow',
    copy: 'The IRS has described Form 4547 and online election mechanics for the $1,000 pilot deposit, while operational rollout details and custodian onboarding timelines may continue to evolve.'
  },
  {
    pill: 'Unknown adoption',
    title: 'Employer participation',
    copy: 'The $2,500-per-year employer contribution is permitted, but actual employer adoption rates are still uncertain.'
  },
  {
    pill: 'State variance',
    title: 'Tax conformity',
    copy: 'Federal treatment may not map cleanly to every state. California-specific kiddie-tax behavior is available as an optional layer; other states are not modeled.'
  },
  {
    pill: 'Reserved rules',
    title: 'Aid and rollover treatment',
    copy: 'Treatment under the new SAI (Student Aid Index) financial-aid formula and the precise age-18 rollover rules still depend on final guidance.'
  }
];
---

<AppLayout
  activeTab="how-it-works"
  title="How It Works | 530A Account Planner"
  description="Understand the college savings account lifecycle, the inputs behind the projection, and how to read the simulated results."
>
  <section class="route-page">
    <section class="container section-spacing route-page__lead">
      <div class="section-frame section-frame--split how-hero">
        <div class="section-intro how-hero__copy">
          <span class="section-kicker">How It Works</span>
          <h1 class="section-title">One clear view of the account lifecycle, the model, and the result.</h1>
          <p class="section-copy">
            This page describes how the calculator models a Trump Account under current federal guidance and
            proposed 2025 regulations. It is a planning illustration, not tax or legal advice — the pilot deposit,
            growth window, and return engine are modeling inputs shaped by the selected birth year,
            not universal facts.
          </p>

          <div class="how-hero__meta">
            <div class="how-hero__meta-item">
              <span>Modeled federal seed</span>
              <strong>$1,000</strong>
            </div>
            <div class="how-hero__meta-item">
              <span>Growth window</span>
              <strong>Up to 18 years</strong>
            </div>
            <div class="how-hero__meta-item">
              <span>Simulation depth</span>
              <strong>1,000 paths × 12/yr</strong>
            </div>
          </div>
        </div>

        <div class="how-lifecycle-board">
          <div class="how-lifecycle-board__header">
            <span class="how-lifecycle-board__eyebrow">Lifecycle map</span>
            <strong>Birth to adulthood</strong>
          </div>

          <div class="how-lifecycle-track">
            {milestones.map((milestone, index) => (
              <article class={`how-lifecycle-milestone is-${milestone.tone}`}>
                <span class="how-lifecycle-milestone__index">0{index + 1}</span>
                <div class="how-lifecycle-milestone__body">
                  <span class="how-lifecycle-milestone__age">{milestone.age}</span>
                  <h3>{milestone.title}</h3>
                  <p>{milestone.copy}</p>
                </div>
              </article>
            ))}
          </div>

          <div class="how-equation">
            <span>Federal seed</span>
            <b>+</b>
            <span>Family savings</span>
            <b>+</b>
            <span>Employer match</span>
            <b>+</b>
            <span>Market compounding</span>
            <b>=</b>
            <span>Age-18 balance</span>
          </div>
        </div>
      </div>
    </section>

    <section class="container section-spacing" style="padding-top: 0;">
      <div class="section-frame">
        <div class="section-intro">
          <span class="section-kicker">Lifecycle</span>
          <h2 class="section-title">Three stages define the account.</h2>
          <p class="section-copy">
            The page is easier to use when the process is reduced to the decisions that actually matter:
            establish the account, fund it over time, then interpret the age-18 transition correctly.
          </p>
        </div>

        <div class="how-sequence">
          {lifecycle.map((stage) => (
            <article class="how-stage">
              <div class={`how-stage__number is-${stage.tone}`}>{stage.step}</div>
              <div class="how-stage__content">
                <span class="how-stage__eyebrow">{stage.eyebrow}</span>
                <h3>{stage.title}</h3>
                <p>{stage.copy}</p>
                <ul class="how-stage__points">
                  {stage.points.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
              </div>
              <div class={`how-stage__tag is-${stage.tone}`}>{stage.tag}</div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="container section-spacing" style="padding-top: 0;">
      <div class="section-frame section-frame--split how-framework">
        <div>
          <div class="section-intro how-framework__intro">
            <span class="section-kicker">Model Logic</span>
            <h2 class="section-title">What the calculator actually changes.</h2>
            <p class="section-copy">
              The simulator is not a black box. The drivers below are what a user can move; everything else
              — monthly compounding using S&amp;P 500 statistics and the stochastic tuition growth — is held
              fixed across scenarios so two configurations stay directly comparable. The child's birth year
              controls the seed, growth window, and transition year.
            </p>
          </div>

          <div class="how-driver-list">
            {drivers.map((driver) => (
              <article class="how-driver">
                <span class="how-driver__value">{driver.value}</span>
                <div class="how-driver__body">
                  <h3>{driver.title}</h3>
                  <p>{driver.copy}</p>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="how-output-panel">
          <span class="section-kicker">Reading the Output</span>
          <h2 class="how-output-panel__title">What each result actually means.</h2>
          <p class="how-output-panel__copy">
            The calculator is easiest to trust when the readout is explicit about what it is showing and what it is not.
          </p>

          <div class="how-output-list">
            {outputs.map((output, index) => (
              <article class="how-output">
                <span class="how-output__index">0{index + 1}</span>
                <div class="how-output__body">
                  <h3>{output.title}</h3>
                  <p>{output.copy}</p>
                </div>
              </article>
            ))}
          </div>

          <a class="how-inline-link" href={base}>
            Open the calculator
          </a>
        </div>
      </div>
    </section>

    <section class="container section-spacing" style="padding-top: 0;">
      <div class="section-frame">
        <div class="section-intro">
          <span class="section-kicker">Watchpoints</span>
          <h2 class="section-title">A few rules are still moving.</h2>
          <p class="section-copy">
            The projection assumes clean execution, but families should still treat these topics as live policy variables.
          </p>
        </div>

        <div class="how-watch-grid">
          {watchpoints.map((watchpoint) => (
            <article class="how-watch-item">
              <span class="how-watch-item__pill">{watchpoint.pill}</span>
              <h3>{watchpoint.title}</h3>
              <p>{watchpoint.copy}</p>
            </article>
          ))}
        </div>

        <p class="section-copy" style="margin-top: 1.5rem;">
          <strong>What this page does not model:</strong> non-California state taxes, employer match adoption
          probabilities, custodian fees, contribution-cap inflation indexing beyond the current statutory
          values, the precise SAI financial-aid calculation, and any future legislative or regulatory changes
          to the proposed 2025 rules.
        </p>
      </div>
    </section>
  </section>
</AppLayout>
