---
import { ClientRouter } from 'astro:transitions';
import FloatingNav from '../components/FloatingNav.astro';
import '../styles/global.css';

interface Props {
  activeTab: 'calculator' | 'faq' | 'how-it-works' | 'about-us';
  title: string;
  description: string;
}

const { activeTab, title, description } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <ClientRouter />
    <script is:inline>
      const savedTheme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
  </head>
  <body>
    <div class="page-shell">
      <div class="page-backdrop" aria-hidden="true"></div>

      <FloatingNav activeTab={activeTab} />

      <main class="page-main">
        <slot />
      </main>

      <footer class="page-footer">
        <div class="footer-disclaimer">
          <p class="footer-disclaimer__title">Important Disclaimer</p>
          <p>
            This website is for informational and educational purposes only and does not constitute
            investment advice, financial advice, tax advice, or any other kind of professional advice.
            The creators of this site are not licensed financial advisors, tax professionals, or
            registered investment advisors. All projections, simulations, and calculations are
            hypothetical illustrations based on historical data and assumptions that may not reflect
            future performance. <strong>Past performance is not indicative of future results.</strong>
          </p>
          <p>
            You should consult a qualified financial advisor, tax professional, or other appropriate
            expert before making any investment or financial decisions. Any reliance you place on the
            information provided by this site is strictly at your own risk.
          </p>
        </div>
        <p class="footer-source">
          Sources: S&amp;P 500 data from ^GSPC Yahoo Finance · IRS Trump Accounts guidance · Form 4547 instructions ·
          Notice 2025-68 · Proposed Regulations for IRC §§ 530A, 6434, 128 · CA FTB conformity guidance.
          Last reviewed: April 24, 2026.
        </p>
      </footer>
    </div>
  </body>
</html>
